---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  { id: "datsun", title: "Datsun 1200", category: "Restoration", specs: ["Loom Repair", "Rust Remediation", "Interior"], image: `${base}/datsun.jpg` },
  { id: "gallery-robot", title: "Gallery Robot", category: "Robotics", specs: ["ROS 2", "OpenCV", "90% Success"], image: `${base}/gallery.jpg` },
  { id: "defender", title: "Land Rover", category: "Modification", specs: ["Solar Wiring", "Winch", "Storage"], image: `${base}/defender.jpg` },
  { id: "pedometer", title: "Pedometer Shield", category: "Embedded", specs: ["Custom PCB", "Altium", "Arduino"], image: `${base}/pedometer.jpg` },
  { id: "pliers", title: "Printed Pliers", category: "Manufacturing", specs: ["Print-in-Place", "Tolerance", "CAD"], image: `${base}/pliers.jpg` }
];
---

<Layout title="Dylan Purbrick | Overview" activeTab="home">
  <div class="max-w-6xl mx-auto">
    <section class="mb-32">
        <h1 class="text-7xl md:text-[9rem] leading-[0.85] tracking-tighter uppercase mb-16 text-industrial-black">
            <span class="font-wayfinder italic">Dylan</span> <br /> 
            <span class="font-neue text-brand-orange">Purbrick</span>
        </h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start font-neue">
            <div class="space-y-8">
                <div class="flex items-center gap-4">
                    <div class="h-[1px] w-12 bg-brand-purple"></div>
                    <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">Personal Profile</p>
                </div>
                <p class="text-2xl text-slate-700 leading-snug font-medium">
                    I am currently undergoing my final-year of study of a Bachelor of Engineering (Honours) in Mechatronic Engineering at UTS, and currently an Engineering Assistant at Keith Engineering.
                </p>
                <p class="text-lg text-slate-500 leading-relaxed">
                    My professional journey is driven by a deep passion for furthering my mechanical understanding and gaining hands-on experience.
                </p>
            </div>
            
            <div class="bg-white/50 p-10 rounded-2xl border border-slate-200 shadow-sm space-y-6">
                <p class="text-sm text-slate-600 leading-loose">
                    Beyond technical aptitude in Python and SolidWorks, I offer proven transferable skills developed through leadership roles, including co-founding the UTS MechSoc and supervising teams in fast-paced environments.
                </p>
                <a href={`${base}/resume`} class="inline-flex items-center gap-4 text-brand-orange font-black uppercase text-[10px] tracking-widest hover:text-brand-purple transition-all group">
                    <span>View Career Summary</span>
                    <span class="group-hover:translate-x-2 transition-transform">→</span>
                </a>
            </div>
        </div>
    </section>

    <section id="projects">
      <div class="mb-12 border-b border-slate-200 pb-6 flex justify-between items-end">
        <h2 class="text-4xl font-black uppercase tracking-tighter text-industrial-black">
            <span class="font-wayfinder italic">Portfolio</span> <span class="text-brand-orange">Systems</span>
        </h2>
        <p class="font-mono text-[9px] uppercase tracking-widest text-slate-400">Section 02 // Technical_Archive</p>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard client:load {...project} />
        ))}
      </div>
    </section>
  </div>
</Layout>
