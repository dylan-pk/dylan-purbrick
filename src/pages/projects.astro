---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  {
    id: "gallery-host",
    title: "Autonomous Gallery Host Robot",
    category: "Autonomous Systems // ROS 2",
    image: `${base}/gallery.jpg`,
    github: "https://github.com/dylanpurbrick/gallery-host",
    details: {
      what: "Develop a ROS 2 perception subsystem to identify artworks using template matching on real-time camera data and integrate with navigation and human interaction systems.",
      how: [
        "Implemented a ROS 2 Python node using rclpy for live camera feed subscription.",
        "Utilized OpenCV’s ORB algorithm for feature extraction and template matching.",
        "Created a ROS service (perform_template_matching) for real-time analysis and confidence scoring.",
        "Packaged using setup.py, CMakeLists.txt, and package.xml for ROS 2 compatibility."
      ],
      results: "Subsystem successfully identified artworks with 90% confidence 90% of times tested. Fully integrated with navigation for physical demonstration."
    }
  },
  {
    id: "datsun-1200",
    title: "Datsun 1200 Restoration",
    category: "Automotive Engineering // Restoration",
    image: `${base}/datsun.jpg`,
    details: {
      what: "Restore and modernise a 1971 Datsun 1200, addressing key electrical faults while retaining original character through practical upgrades.",
      how: [
        "Repaired faulty rear lights and fuel sensor wiring in the main loom; replaced starter motor.",
        "Installed modern thermal insulation and sound deadening beneath new interior carpet.",
        "Upgraded head unit and speakers for an improved audio system.",
        "Performed general fault diagnosis and parts replacement across interior systems."
      ],
      results: "Electrical system fully restored to consistent operation. Improved reliability and comfort without compromising classic integrity."
    }
  },
  {
    id: "pedometer",
    title: "Prototype Pedometer",
    category: "Embedded Systems // PCB Design",
    image: `${base}/pedometer.jpg`,
    details: {
      what: "Design and source a custom PCB shield for an Arduino UNO R3 to interface with an ADXL335 accelerometer.",
      how: [
        "Used Altium365 to create schematics and ECAD for the custom PCB shield.",
        "Programmed step and walking pace identification functions in Arduino C++.",
        "Soldered the physical PCB shield and designed a mechanical enclosure."
      ],
      results: "Design fulfilled its purpose with >90% accuracy. Final PCB achieved full marks with no hardware hacks required."
    }
  },
  {
    id: "defender-mod",
    title: "Land Rover Defender Modification",
    category: "Electrical Integration // Off-Grid",
    image: `${base}/defender.jpg`,
    details: {
      what: "Upgrade a 2016 Land Rover Defender with off-grid electrical capability and external recovery hardware for remote travel.",
      how: [
        "Designed/installed auxiliary power system with solar charging, fridge, and exterior lighting terminals.",
        "Rewired head unit for modern connectivity and audio performance.",
        "Installed electric winch and aftermarket bull bar, including electrical routing and structural mounting."
      ],
      results: "Supports reliable off-grid operation with modular power usage. Improved safety and recovery capability for remote living."
    }
  },
  {
    id: "printed-pliers",
    title: "3D Print-in-Place Pliers",
    category: "Additive Manufacturing // CAD",
    image: `${base}/pliers.jpg`,
    details: {
      what: "Design and produce fully functional, print-in-place pliers optimizing for grip strength and ergonomics without post-processing.",
      how: [
        "Designed interlocking geometry in CAD to form a functional rotational joint.",
        "Applied tight tolerance control to ensure smooth motion between integrated halves.",
        "Printed in PLA with no supports or assembly required."
      ],
      results: "Produced functional pliers with smooth motion and strong grip. Demonstrated high proficiency in design for additive manufacturing (DfAM)."
    }
  }
];
---

<Layout title="Technical Archive" activeTab="projects">
  <div class="max-w-6xl mx-auto">
    <header class="mb-24 border-b border-slate-200 pb-12">
        <h1 class="text-6xl font-black uppercase tracking-tighter mb-4 text-industrial-black">Technical Archive</h1>
        <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">Engineering Proofs & Project Documentation</p>
    </header>

    <div class="space-y-32">
        {projects.map((project) => (
            <div id={project.id} class="scroll-mt-32">
                <ProjectCard client:load {...project} />
            </div>
        ))}
    </div>
  </div>
</Layout>