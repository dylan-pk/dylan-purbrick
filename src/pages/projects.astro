---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  {
    id: "wallbug",
    title: "Wallbug // Vertical Garden Monitor",
    category: "Environmental Monitoring // Embedded Systems",
    images: [`${base}/images/wallbug/hero.jpg`, `${base}/images/wallbug/02-topdown-hardware.jpg`, `${base}/images/wallbug/03-scaled-case-print.jpg`, `${base}/images/wallbug/04-handover-meeting.png` ],
    demo: "https://dylan-pk.github.io/Wallbug/",
    video: "https://www.linkedin.com/posts/dylan-purbrick_over-the-last-semester-i-had-the-privilege-ugcPost-7398840787922427904-iWva?utm_source=share&utm_medium=member_desktop&rcm=ACoAAElRDFgB_Rpe-w4WWAL1G5y4Ctiopo0a81g",
    github: "https://github.com/dylan-pk/Wallbug",
    details: {
      what: "A vertical garden monitoring robot integrating environmental sensing with automated irrigation and real-time data logging.",
      how: [
        "Integrated sensor array for soil moisture, ambient temperature, and humidity levels.",
        "Developed WiFi-based logging system for remote environmental monitoring.",
        "Engineered automated irrigation trigger based on moisture threshold analysis.",
        "Designed vertical-specific chassis for stable mounting and mobility."
      ],
      results: "Successfully automated maintenance of a vertical garden system with high reliability and zero plant loss."
    }
  },
  {
    id: "gallery-host",
    title: "Autonomous Gallery Host Robot",
    category: "Autonomous Systems // ROS 2",
    images: [`${base}/images/gallery/hero.jpg`, `${base}/images/gallery/02-image-match-visual.jpg`, `${base}/images/gallery/03-image-match-terminal.png`, `${base}/images/gallery/04-local-map.png`],
    portfolio: `${base}/docs/GalleryHost_Portfolio_DP.pdf`,
    github: "https://github.com/dylan-pk/Gallery-Greeters",
    details: {
      what: "Develop a ROS 2 perception subsystem to identify artworks using template matching on real-time camera data and integrate with navigation systems.",
      how: [
        "Implemented a ROS 2 Python node using rclpy to subscribe to a live camera feed.",
        "Used OpenCV’s ORB algorithm to extract features and match templates.",
        "Created a ROS service to trigger real-time image analysis.",
        "Verified functionality in both simulated and real-world environments."
      ],
      results: "Identified artworks with 90% confidence 90% of times tested. Fully integrated with navigation for physical demonstration."
    }
  },
  {
    id: "datsun-1200",
    title: "Datsun 1200 Restoration",
    category: "Automotive Engineering // Restoration",
    images: [`${base}/images/datsun-1200/hero.jpg`, `${base}/images/datsun-1200/02-insulation.jpg`, `${base}/images/datsun-1200/03-carpet.jpg`, `${base}/images/datsun-1200/04-rear-badge.jpg`],
    details: {
      what: "Restore and modernise a 1971 Datsun 1200, addressing electrical faults and improving interior usability while retaining original character.",
      how: [
        "Repaired faulty rear lights and fuel sensor wiring in the main loom.",
        "Installed modern thermal insulation and sound deadening beneath new carpet.",
        "Upgraded head unit and speakers for improved audio system.",
        "Performed general fault diagnosis and parts replacement."
      ],
      results: "Improved reliability and comfort. Electrical system fully restored to consistent operation."
    }
  },
  {
    id: "pedometer",
    title: "Prototype Pedometer",
    category: "Embedded Systems // PCB Design",
    images: [`${base}/images/pedometer/hero.jpg`, `${base}/images/pedometer/02-pcb-layout.jpg`, `${base}/images/pedometer/03-enclosure-render.jpg`, `${base}/images/pedometer/04-top-down-powered.jpg],
    portfolio: `${base}/docs/CustomPedometer_Portfolio_DP.pdf`,
    details: {
      what: "Design and source a custom PCB shield for an Arduino UNO R3 to interface with ADXL335; create a step tracker program.",
      how: [
        "Used Altium365 to create schematics and ECAD for custom PCB.",
        "Programmed step identification functions using Arduino C++.",
        "Soldered the physical PCB shield and designed mechanical enclosure."
      ],
      results: "Design fulfilled its purpose with >90% accuracy. Final PCB achieved full marks with no hacks."
    }
  },
  {
    id: "defender-mod",
    title: "Land Rover Defender Modification",
    category: "Electrical Integration // Off-Grid",
    images: [`${base}/images/defender-1.jpg`, `${base}/images/defender-2.jpg`],
    details: {
      what: "Upgrade a 2016 Land Rover Defender with off-grid electrical capability and external recovery hardware.",
      how: [
        "Designed and installed auxiliary power system with solar charging and fridge terminals.",
        "Rewired head unit for modern connectivity.",
        "Installed electric winch and aftermarket bull bar including electrical routing."
      ],
      results: "Supports reliable off-grid operation. Improved safety and recovery capability for remote driving."
    }
  },
  {
    id: "printed-pliers",
    title: "3D Print-in-Place Pliers",
    category: "Additive Manufacturing // CAD",
    images: [`${base}/images/pliers/hero.jpg`, `${base}/images/pliers/02-plier-render.png`, `${base}/images/plier/03-slice.png],
    details: {
      what: "Design and produce fully functional, print-in-place pliers optimizing for grip strength without post-processing.",
      how: [
        "Designed interlocking geometry in CAD to form a functional rotational joint.",
        "Applied tolerance control for smooth motion between integrated halves.",
        "Printed in PLA with no supports or assembly required."
      ],
      results: "Produced functional pliers with smooth motion. Design received high academic grade for effectiveness."
    }
  },
  {
    id: "crop-guard",
    title: "Crop-Guard // Agricultural Monitor",
    category: "Agricultural Robotics // Simulation",
    images: [`${base}/images/crop-guard/hero.jpg`, `${base}/images/crop-guard/02-map-markers.png`, `${base}/images/crop-guard/03-map-sim.png`, `${base}/images/crop-guard/04-map-scan.png`],
    portfolio: `${base}/docs/CropGuard_Portfolio_DP.pdf`,
    github: "https://github.com/dylan-pk/Crop-Guard",
    details: {
      what: "An autonomous agricultural monitoring robot simulation designed for large-scale crop health tracking.",
      how: [
        "Built simulation environment in Simulink for autonomous pathing.",
        "Implemented sensor array processing for crop health assessment.",
        "Developed obstacle avoidance algorithms for complex terrain."
      ],
      results: "Achieved 95% coverage rate in simulated environments."
    }
  }
];
---

<Layout title="Technical Archive" activeTab="projects">
  <div class="max-w-6xl mx-auto relative z-10">
    <header class="mb-32 border-b border-slate-200 pb-12">
        <h1 class="text-6xl font-black uppercase tracking-tighter mb-4 text-industrial-black">Technical Archive</h1>
        <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">Engineering Projects & Documentation</p>
    </header>

    <div class="space-y-48 pb-48">
        {projects.map((project) => (
            <div id={project.id} class="scroll-mt-40">
                <ProjectCard client:load {...project} />
            </div>
        ))}
    </div>
  </div>
</Layout>