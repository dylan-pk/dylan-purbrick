---
import '../styles/global.css';
const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';

const tabs = [
    { id: 'home', label: 'Overview', path: '/' },
    { id: 'cover-letter', label: 'Cover Letter', path: '/cover-letter', uniOnly: true },
    { id: 'projects', label: 'Projects', path: '/projects' },
    { id: 'resume', label: 'Resume', path: '/resume' },
    { id: 'uni', label: 'Reflection', path: '/uni', uniOnly: true },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/icon.svg`} />
		<title>{title} | Dylan Purbrick</title>
		
		<style is:global>
			@reference "../styles/global.css";

			html, body { overscroll-behavior-y: none; }
			.bg-engineering-grid {
				background-color: #0f172a; 
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.08) 2px, transparent 2px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.08) 2px, transparent 2px);
				background-size: 128px 128px;
				background-attachment: fixed;
			}
            
            /* MASTER TYPOGRAPHY SYSTEM 
               Edit these 3 lines to update your entire site's font system 
            */
            .text-order-1 { @apply text-[10px] font-black uppercase tracking-[0.3em] text-slate-500; }
            .text-order-2 { @apply text-[14px] leading-relaxed text-slate-700; }
            .text-order-3 { @apply text-[10px] font-mono text-slate-400 uppercase tracking-widest; }
		</style>
	</head>
	<body class="bg-engineering-grid text-industrial-black font-neue antialiased min-h-screen transition-opacity duration-500 opacity-100">
		
		<div class="relative z-10 max-w-6xl mx-auto flex flex-col md:flex-row min-h-screen pt-24 pb-48 px-4 md:px-0">
			
			<aside class="w-full md:w-24 lg:w-26 flex-shrink-0 flex flex-row md:flex-col items-start relative md:-mr-4 overflow-x-auto md:overflow-visible no-scrollbar mb-8 md:mb-0">
				{tabs.map((tab) => {
					const isActive = activeTab === tab.id;
					return (
						<div id={`${tab.id}-tab-wrapper`} class={`min-w-[110px] md:w-full relative ${isActive ? 'z-30' : 'z-10'} ${tab.uniOnly ? 'hidden' : 'block'}`}>
							<a 
								href={`${base}${tab.path}`} 
								class={`nav-tab group relative flex items-center justify-center transition-all duration-500 backdrop-blur-md outline-none
									${isActive 
                                        ? 'bg-[#f1f5f9] text-brand-purple py-6 md:py-20 rounded-xl md:rounded-l-xl md:rounded-r-none border-y border-l border-slate-200 border-r-0 translate-x-[1px] md:w-[calc(100%+2px)] shadow-[2px_0_0_#f1f5f9]' 
                                        : 'w-full bg-slate-800/80 text-slate-100 py-4 md:py-10 rounded-xl border border-white/10 hover:md:py-12 hover:bg-slate-700'}
								`}
							>
								{isActive && <div class="absolute bottom-0 md:bottom-auto md:left-0 left-1/4 right-1/4 md:right-auto md:top-1/4 md:bottom-1/4 h-1 md:w-1 md:h-auto bg-brand-orange rounded-t-full md:rounded-r-full shadow-[0_-2px_10px_rgba(234,88,12,0.4)]"></div>}
								<span class="text-[9px] font-black uppercase tracking-[0.15em] inline-block md:rotate-180 opacity-100" style="writing-mode: vertical-rl; text-orientation: mixed;">
									{tab.label}
								</span>
							</a>
						</div>
					);
				})}
			</aside>

			<main id="main-content" class="flex-1 bg-[#f1f5f9] min-h-[85vh] rounded-3xl md:rounded-l-none md:rounded-r-3xl md:rounded-tr-3xl relative z-20 border border-slate-200 flex flex-col overflow-y-auto shadow-[-20px_0_50px_-15px_rgba(0,0,0,0.15),_0_40px_100px_rgba(0,0,0,0.4)]">
                <div class="p-8 md:p-16 lg:p-20 relative z-10 flex-1">
					<slot />
				</div>

				<footer class="mt-auto border-t border-slate-200 p-8 md:px-16 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-order-3">© 2026 Dylan Purbrick | Undergraduate Engineer</p>
					<a href="mailto:dylan.m.purbrick@gmail.com" class="text-order-1 hover:text-brand-orange transition-colors lowercase tracking-normal">dylan.m.purbrick@gmail.com</a>
				</footer>
			</main>
		</div>

		<script define:vars={{ tabs, base, activeTab }}>
			function initSystem() {
				const params = new URLSearchParams(window.location.search);
				const isUniMode = params.get('mode') === 'uni';
				let isSystemArmed = false;
                let isTransitioning = false;
				setTimeout(() => { isSystemArmed = true; }, 1200);

				if (isUniMode) {
					document.querySelectorAll('[id$="-tab-wrapper"]').forEach(el => {
						if (el.id.includes('uni') || el.id.includes('cover-letter')) {
							el.classList.remove('hidden');
						}
					});
				}

				const fadeAndGo = (url) => {
                    if (isTransitioning) return;
                    isTransitioning = true;
					document.body.style.opacity = '0';
					setTimeout(() => window.location.href = url, 500);
				};

                // GLOBAL NAVIGATION INTERCEPTOR: Preserves Uni Mode across the whole site
                document.addEventListener('click', (e) => {
                    const link = e.target.closest('a');
                    if (link && isUniMode && link.href.startsWith(window.location.origin)) {
                        const url = new URL(link.href);
                        if (!url.searchParams.has('mode')) {
                            e.preventDefault();
                            url.searchParams.set('mode', 'uni');
                            fadeAndGo(url.toString());
                        }
                    }
                });

				const activeSequence = tabs.filter(t => !t.uniOnly || isUniMode);
				const currentIndex = activeSequence.findIndex(t => t.id === activeTab);
				const nextSection = activeSequence[currentIndex + 1];
                const prevSection = activeSequence[currentIndex - 1];

                window.addEventListener('scroll', () => {
                    if (!isSystemArmed || isTransitioning) return;
                    const scrollPos = window.scrollY;
                    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
                    if (nextSection && scrollPos >= maxScroll - 5) {
                        const url = new URL(window.location.origin + base + nextSection.path);
                        if (isUniMode) url.searchParams.set('mode', 'uni');
                        fadeAndGo(url.toString());
                    }
                }, { passive: true });

                window.addEventListener('wheel', (e) => {
                    if (isSystemArmed && !isTransitioning && prevSection && window.scrollY <= 0 && e.deltaY < -25) {
                        const url = new URL(window.location.origin + base + prevSection.path);
                        if (isUniMode) url.searchParams.set('mode', 'uni');
                        fadeAndGo(url.toString());
                    }
                }, { passive: true });
			}

			initSystem();
			document.addEventListener('astro:page-load', initSystem);
		</script>
	</body>
</html>