---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  { 
    id: "agricultural-monitor", 
    title: "Crop-Guard", 
    category: "Agricultural Robotics", 
    specs: ["Autonomous Navigation", "Simulink", "Crop Health Monitoring"], 
    image: `${base}/ag-robot.jpg`,
    github: "https://github.com/dylan-pk/Crop-Guard",
    portfolio: `${base}/Crop_Guard_Portfolio.pdf`
  },
  { 
    id: "vertical-garden", 
    title: "Wallbug", 
    category: "Environmental Monitoring", 
    specs: ["Vertical Mobility", "Sensor Integration", "Real-time Logging"], 
    image: `${base}/wallbug.jpg`,
    github: "https://github.com/dylan-pk/Wallbug",
    // Use the absolute URL here to prevent 404 issues
    demo: "https://dylan-pk.github.io/Wallbug/", 
    portfolio: `${base}/Wallbug_Portfolio.pdf`
  },
  { 
    id: "gallery-robot", 
    title: "Gallery Robot", 
    category: "Autonomous Systems", 
    specs: ["ROS 2", "OpenCV", "90% Success Rate"], 
    image: `${base}/gallery.jpg`,
    github: "https://github.com/dylan-pk/Gallery-Greeters",
    portfolio: `${base}/Gallery_Robot_Portfolio.pdf`
  },
  { 
    id: "printed-pliers", 
    title: "Printed Pliers", 
    category: "Additive Manufacturing", 
    specs: ["Print-in-Place", "Fusion 360", "Tolerance Control"], 
    image: `${base}/pliers.jpg` 
  },
  { 
    id: "datsun", 
    title: "Datsun 1200", 
    category: "Restoration", 
    specs: ["Loom Repair", "Rust Remediation", "Interior Refresh"], 
    image: `${base}/datsun.jpg` 
  },
  { 
    id: "defender", 
    title: "Land Rover Defender", 
    category: "System Modification", 
    specs: ["Solar Integration", "Winch Wiring", "Storage Design"], 
    image: `${base}/defender.jpg` 
  }
];
---

<Layout title="Dylan Purbrick | Projects" activeTab="projects">
  <div class="max-w-6xl relative z-10">
    <header class="mb-24 border-b border-slate-200 pb-12">
        <h1 class="text-6xl font-black uppercase tracking-tighter mb-4">Technical Archive</h1>
        <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">Engineering Proofs & Personal Build Log</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((p) => <ProjectCard client:load {...p} />)}
    </div>
  </div>
</Layout>
