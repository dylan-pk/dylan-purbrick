---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#334155] text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden">
		<div class="fixed inset-0 pointer-events-none opacity-[0.07] z-0 bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>

		<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row min-h-screen">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch pt-24 gap-[2px] relative z-30">
				
				<a href={`${base}/`} 
				   class={`relative flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all border-l border-y border-slate-300/30 ${activeTab === 'home' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[2px] border-r-transparent' : 'bg-slate-200/80 text-slate-400 hover:bg-slate-200 z-10'}`}>
					{activeTab === 'home' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1.5 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
						01. Overview
					</span>
				</a>

				<a href={`${base}/projects`} 
				   class={`relative flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all border-l border-y border-slate-300/30 ${activeTab === 'projects' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[2px] border-r-transparent' : 'bg-slate-200/80 text-slate-400 hover:bg-slate-200 z-10'}`}>
					{activeTab === 'projects' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1.5 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
						02. Projects
					</span>
				</a>

				<a href={`${base}/resume`} 
				   class={`relative flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all border-l border-y border-slate-300/30 ${activeTab === 'resume' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[2px] border-r-transparent' : 'bg-slate-200/80 text-slate-400 hover:bg-slate-200 z-10'}`}>
					{activeTab === 'resume' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1.5 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
						03. Resume
					</span>
				</a>

				<div id="uni-indicator" class="hidden">
					<a href={`${base}/uni?mode=uni`} 
					   class={`relative flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all border-l border-y border-slate-300/30 ${activeTab === 'uni' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[2px] border-r-transparent' : 'bg-brand-purple text-white hover:bg-brand-orange z-10'}`}>
						{activeTab === 'uni' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1.5 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
						<span class="text-[9px] font-black uppercase tracking-widest inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
							Academic Hub
						</span>
					</a>
				</div>
			</aside>

			<main class="flex-1 bg-[#f1f5f9] shadow-[0_0_80px_rgba(0,0,0,0.4)] min-h-screen rounded-r-3xl md:rounded-tr-3xl relative z-20 border-l border-slate-200">
				<div class="p-8 md:p-16 lg:p-24 relative z-10">
					<slot />
				</div>
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/paper.png')]"></div>
			</main>
		</div>

		<footer class="relative z-10 bg-slate-900 py-24 px-6 border-t border-white/5">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
				<div class="text-center md:text-left">
					<h2 class="font-neue font-black uppercase text-3xl text-white mb-2 tracking-tighter">Dylan Purbrick</h2>
					<p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Mechatronic Engineering // UTS 2026</p>
				</div>
				<div class="flex flex-col sm:flex-row items-center gap-8">
					<a href="mailto:dylan.m.purbrick@gmail.com" class="bg-brand-orange text-white px-14 py-6 rounded-sm text-[12px] font-black uppercase tracking-[0.25em] hover:bg-brand-purple hover:-translate-y-2 transition-all shadow-[0_20px_40px_rgba(234,88,12,0.3)]">
						Get In Touch via Email
					</a>
					<a href="https://linkedin.com/in/dylan-purbrick" target="_blank" class="text-slate-400 hover:text-white text-[10px] font-bold uppercase tracking-widest transition-colors">
						LinkedIn Profile
					</a>
				</div>
			</div>
		</footer>

		<script>
			function updateUniMode() {
				const params = new URLSearchParams(window.location.search);
				if (params.get('mode') === 'uni') {
					document.getElementById('uni-indicator')?.classList.remove('hidden');
					document.querySelectorAll('a').forEach(link => {
						const href = link.getAttribute('href');
						if (href && (href.startsWith('/') || href.startsWith(window.location.origin))) {
							const url = new URL(href, window.location.origin);
							url.searchParams.set('mode', 'uni');
							link.href = url.pathname + url.search + url.hash;
						}
					});
				}
			}
			updateUniMode();
			document.addEventListener('astro:page-load', updateUniMode);
		</script>
	</body>
</html>
