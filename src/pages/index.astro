---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  { id: "datsun", title: "Datsun 1200", category: "Restoration", specs: ["Loom Repair", "Rust Remediation", "Interior"], image: `${base}/datsun.jpg` },
  { id: "gallery-robot", title: "Gallery Robot", category: "Robotics", specs: ["ROS 2", "OpenCV", "90% Success"], image: `${base}/gallery.jpg` },
  { id: "defender", title: "Land Rover", category: "Modification", specs: ["Solar Wiring", "Winch", "Storage"], image: `${base}/defender.jpg` },
  { id: "pedometer", title: "Pedometer Shield", category: "Embedded", specs: ["Custom PCB", "Altium", "Arduino"], image: `${base}/pedometer.jpg` },
  { id: "pliers", title: "Printed Pliers", category: "Manufacturing", specs: ["Print-in-Place", "Tolerance", "CAD"], image: `${base}/pliers.jpg` }
];
---

<Layout title="Dylan Purbrick | Mechatronic Portfolio">
  <main class="mx-auto max-w-7xl px-6 pt-48 pb-32">
    <section class="mb-48">
        <h1 class="text-8xl md:text-[11rem] leading-[0.8] tracking-tighter uppercase mb-12">
            <span class="font-wayfinder text-industrial-black">Dylan</span> <br /> 
            <span class="font-neue text-brand-orange">Purbrick</span>
        </h1>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-start font-neue">
            <div class="space-y-6">
                <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">// Personal Profile</p>
                <p class="text-xl text-gray-600 leading-relaxed">
                    I am currently undergoing my final-year of study of a Bachelor of Engineering (Honours) in Mechatronic Engineering at UTS, and currently an Engineering Assistant at Keith Engineering[cite: 101]. My professional journey is driven by a deep passion for furthering my mechanical understanding and gaining hands-on experience[cite: 102].
                </p>
            </div>
            <div class="border-l border-gray-100 pl-10 space-y-4">
                <p class="text-sm text-gray-500 leading-loose">
                    Beyond technical aptitude in Python and SolidWorks, I offer proven transferable skills developed through leadership roles, including co-founding the UTS MechSoc and supervising teams in fast-paced environments[cite: 106].
                </p>
                <a href={`${base}/resume`} class="inline-block border-b-2 border-brand-orange text-brand-orange font-bold uppercase text-[10px] tracking-widest pt-4 hover:text-brand-purple hover:border-brand-purple transition-all">
                    View Career Summary →
                </a>
            </div>
        </div>
    </section>

    <section id="projects">
      <div class="mb-12 border-b-2 border-industrial-black pb-4 flex justify-between items-end">
        <h2 class="text-5xl font-black uppercase tracking-tighter">
            <span class="font-wayfinder">Portfolio</span> <span class="font-neue text-brand-orange">Systems</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard client:load {...project} />
        ))}
      </div>
    </section>
  </main>
</Layout>
