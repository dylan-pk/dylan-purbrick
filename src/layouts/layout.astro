---
import '../styles/global.css';
interface Props {
	title: string;
	activeTab: 'home' | 'cover-letter' | 'projects' | 'resume' | 'uni';
}
const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
	</head>
	<body class="bg-[#334155] text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden">
		<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row min-h-screen pt-24 pb-48 px-4 md:px-0">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch relative z-30 transition-all">
				
				<a href={`${base}/`} 
				   class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${activeTab === 'home' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-16' : 'bg-slate-300/40 text-slate-500 hover:bg-slate-300/60 py-8 hover:py-10'}`}>
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">Overview</span>
				</a>

                <div id="cover-letter-indicator" class="hidden">
					<a href={`${base}/cover-letter?mode=uni`} 
					   class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${activeTab === 'cover-letter' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-16' : 'bg-slate-300/40 text-slate-500 hover:bg-slate-300/60 py-8 hover:py-10'}`}>
						<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">Cover Letter</span>
					</a>
				</div>

				<a href={`${base}/projects`} 
				   class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${activeTab === 'projects' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-16' : 'bg-slate-300/40 text-slate-500 hover:bg-slate-300/60 py-8 hover:py-10'}`}>
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">Projects</span>
				</a>

				<a href={`${base}/resume`} 
				   class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${activeTab === 'resume' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-16' : 'bg-slate-300/40 text-slate-500 hover:bg-slate-300/60 py-8 hover:py-10'}`}>
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">Resume</span>
				</a>

				<div id="uni-indicator" class="hidden">
					<a href={`${base}/uni?mode=uni`} 
					   class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-b border-slate-400/20 ${activeTab === 'uni' ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-16' : 'bg-slate-300/40 text-slate-500 hover:bg-slate-300/60 py-8 hover:py-10'}`}>
						<span class="text-[9px] font-black uppercase tracking-widest inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">Professional Reflection</span>
					</a>
				</div>
			</aside>

			<main class="flex-1 bg-[#f1f5f9] shadow-[0_40px_100px_rgba(0,0,0,0.5)] min-h-[85vh] rounded-r-3xl md:rounded-tr-3xl relative z-20 border-l border-slate-200">
				<div class="p-8 md:p-16 lg:p-24 relative z-10">
					<slot />
				</div>
			</main>
		</div>

		<script>
            // Uni-Mode Logic
			function updateUniMode() {
				const params = new URLSearchParams(window.location.search);
				if (params.get('mode') === 'uni') {
					document.getElementById('uni-indicator')?.classList.remove('hidden');
					document.getElementById('cover-letter-indicator')?.classList.remove('hidden');
					document.querySelectorAll('a').forEach(link => {
						const href = link.getAttribute('href');
						if (href && (href.startsWith('/') || href.startsWith(window.location.origin))) {
							const url = new URL(href, window.location.origin);
							url.searchParams.set('mode', 'uni');
							link.href = url.pathname + url.search + url.hash;
						}
					});
				}
			}
			updateUniMode();
			document.addEventListener('astro:page-load', updateUniMode);
		</script>
	</body>
</html>