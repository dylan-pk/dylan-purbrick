---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#334155] text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden">
		<div class="fixed inset-0 pointer-events-none opacity-[0.07] z-0 bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>

		<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row min-h-screen">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch pt-24 gap-1">
				<a href={`${base}/`} 
				   class={`flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all hover:bg-white/10 ${activeTab === 'home' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-15px_0_30px_rgba(0,0,0,0.2)] z-20' : 'bg-slate-700/50 text-slate-400 border-l border-white/10'}`}
				   style="writing-mode: vertical-rl; transform: rotate(180deg); text-orientation: mixed;">
					<span class="text-[10px] font-black uppercase tracking-[0.3em]">01. Overview</span>
				</a>
				<a href={`${base}/projects`} 
				   class={`flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all hover:bg-white/10 ${activeTab === 'projects' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-15px_0_30px_rgba(0,0,0,0.2)] z-20' : 'bg-slate-700/50 text-slate-400 border-l border-white/10'}`}
				   style="writing-mode: vertical-rl; transform: rotate(180deg); text-orientation: mixed;">
					<span class="text-[10px] font-black uppercase tracking-[0.3em]">02. Projects</span>
				</a>
				<a href={`${base}/resume`} 
				   class={`flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all hover:bg-white/10 ${activeTab === 'resume' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-15px_0_30px_rgba(0,0,0,0.2)] z-20' : 'bg-slate-700/50 text-slate-400 border-l border-white/10'}`}
				   style="writing-mode: vertical-rl; transform: rotate(180deg); text-orientation: mixed;">
					<span class="text-[10px] font-black uppercase tracking-[0.3em]">03. Resume</span>
				</a>

				<div id="uni-indicator" class="hidden">
					<a href={`${base}/uni?mode=uni`} 
					   class={`flex items-center justify-center py-10 px-2 rounded-l-2xl transition-all ${activeTab === 'uni' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-15px_0_30px_rgba(0,0,0,0.2)] z-20' : 'bg-brand-purple text-white hover:bg-brand-orange'}`}
					   style="writing-mode: vertical-rl; transform: rotate(180deg); text-orientation: mixed;">
						<span class="text-[9px] font-black uppercase tracking-widest">Academic Hub</span>
					</a>
				</div>
			</aside>

			<main class="flex-1 bg-[#f1f5f9] shadow-[0_0_80px_rgba(0,0,0,0.4)] min-h-screen rounded-r-3xl md:rounded-tr-3xl relative">
				<div class="p-8 md:p-16 lg:p-24 relative z-10">
					<slot />
				</div>
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/paper.png')]"></div>
			</main>
		</div>

		<footer class="relative z-10 bg-slate-900 py-20 px-6 border-t border-white/5">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
				<div class="text-center md:text-left">
					<h2 class="font-neue font-black uppercase text-3xl text-white mb-2 tracking-tighter">Dylan Purbrick</h2>
					<p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">Mechatronic Engineering // UTS 2026</p>
				</div>
				
				<div class="flex flex-col sm:flex-row items-center gap-8">
					<a href="mailto:dylan.m.purbrick@gmail.com" class="bg-brand-orange text-white px-12 py-5 rounded-sm text-[11px] font-black uppercase tracking-[0.2em] hover:bg-brand-purple hover:-translate-y-1 transition-all shadow-2xl shadow-brand-orange/30">
						Contact Me via Email
					</a>
					<a href="https://linkedin.com/in/dylan-purbrick" target="_blank" class="text-slate-500 hover:text-white text-[10px] font-bold uppercase tracking-widest transition-colors">
						LinkedIn
					</a>
				</div>
			</div>
		</footer>

		<script>
			function updateUniMode() {
				const params = new URLSearchParams(window.location.search);
				if (params.get('mode') === 'uni') {
					document.getElementById('uni-indicator')?.classList.remove('hidden');
					document.querySelectorAll('a').forEach(link => {
						const href = link.getAttribute('href');
						if (href && (href.startsWith('/') || href.startsWith(window.location.origin))) {
							const url = new URL(href, window.location.origin);
							url.searchParams.set('mode', 'uni');
							link.href = url.pathname + url.search + url.hash;
						}
					});
				}
			}
			updateUniMode();
			document.addEventListener('astro:page-load', updateUniMode);
		</script>
	</body>
</html>
