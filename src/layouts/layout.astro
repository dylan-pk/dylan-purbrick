---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0f172a] text-industrial-black font-neue antialiased min-h-screen p-4 md:p-8 lg:p-12">
		
		<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start gap-0">
			<nav class="flex flex-row md:flex-col items-stretch w-full md:w-48 gap-1 pt-12">
				<a href={`${base}/`} 
				   class={`px-6 py-4 rounded-t-xl md:rounded-t-none md:rounded-l-2xl text-[10px] font-black uppercase tracking-widest transition-all text-center md:text-right ${activeTab === 'home' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-10px_0_15px_rgba(0,0,0,0.2)] z-30' : 'bg-[#cbd5e1] text-slate-500 hover:bg-[#dee5ed] z-10'}`}>
					01. Overview
				</a>
				<a href={`${base}/projects`} 
				   class={`px-6 py-4 rounded-t-xl md:rounded-t-none md:rounded-l-2xl text-[10px] font-black uppercase tracking-widest transition-all text-center md:text-right ${activeTab === 'projects' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-10px_0_15px_rgba(0,0,0,0.2)] z-30' : 'bg-[#cbd5e1] text-slate-500 hover:bg-[#dee5ed] z-10'}`}>
					02. Projects
				</a>
				<a href={`${base}/resume`} 
				   class={`px-6 py-4 rounded-t-xl md:rounded-t-none md:rounded-l-2xl text-[10px] font-black uppercase tracking-widest transition-all text-center md:text-right ${activeTab === 'resume' ? 'bg-[#f1f5f9] text-brand-purple shadow-[-10px_0_15px_rgba(0,0,0,0.2)] z-30' : 'bg-[#cbd5e1] text-slate-500 hover:bg-[#dee5ed] z-10'}`}>
					03. Resume
				</a>

				<div id="uni-indicator" class="hidden mt-8 md:mt-12 px-4 md:px-0">
					<a href={`${base}/uni?mode=uni`} 
					   class="block px-6 py-4 rounded-xl md:rounded-r-none md:rounded-l-2xl bg-brand-purple text-white text-[9px] font-black uppercase tracking-widest text-center md:text-right shadow-lg hover:bg-brand-orange transition-colors">
						Academic Hub
					</a>
				</div>
			</nav>

			<div class="flex-1 bg-[#f1f5f9] min-h-[85vh] shadow-[0_20px_50px_rgba(0,0,0,0.5)] rounded-b-3xl md:rounded-tr-3xl md:rounded-bl-none relative overflow-hidden border-l border-white/50">
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>
				
				<div class="relative z-10 p-8 md:p-16 lg:p-20">
					<slot />
				</div>
			</div>
		</div>

		<footer class="max-w-7xl mx-auto mt-12 flex flex-col md:flex-row justify-between items-center px-4 md:pl-52 font-neue text-[10px] text-slate-500 uppercase tracking-widest gap-4">
			<p>© 2026 Dylan Purbrick // Mechatronic Systems Dossier</p>
			<div class="flex gap-8">
				<a href="mailto:dylan.m.purbrick@gmail.com" class="hover:text-brand-orange transition-colors">Email</a>
				<a href="https://linkedin.com/in/dylan-purbrick" target="_blank" class="hover:text-brand-orange transition-colors">LinkedIn</a>
			</div>
		</footer>

		<script>
			function updateUniLinks() {
				const urlParams = new URLSearchParams(window.location.search);
				const isUniMode = urlParams.get('mode') === 'uni';

				if (isUniMode) {
					// 1. Show the academic tab in the side nav
					const indicator = document.getElementById('uni-indicator');
					if (indicator) indicator.classList.remove('hidden');

					// 2. Intercept all internal links to keep the mode active
					document.querySelectorAll('a').forEach(link => {
						const href = link.getAttribute('href');
						if (href && (href.startsWith('/') || href.startsWith(window.location.origin))) {
							try {
								const url = new URL(href, window.location.origin);
								// Only add if it's not already there
								if (url.searchParams.get('mode') !== 'uni') {
									url.searchParams.set('mode', 'uni');
									link.href = url.pathname + url.search + url.hash;
								}
							} catch (e) {
								console.error("Link update failed", e);
							}
						}
					});
				}
			}

			// Run on load
			updateUniLinks();
			
			// Re-run if content changes (for dynamic elements)
			document.addEventListener('astro:page-load', updateUniLinks);
		</script>
	</body>
</html>
