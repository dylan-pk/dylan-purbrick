---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#f8fafc] text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden">
		<div class="fixed inset-0 pointer-events-none opacity-[0.05] z-0 bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>

		<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row min-h-screen">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch pt-24 gap-1">
				<a href={`${base}/`} 
				   class={`flex items-center justify-center py-10 px-2 border-y md:border-y-0 md:border-l-4 transition-all hover:bg-white/50 ${activeTab === 'home' ? 'bg-white border-brand-orange shadow-[-10px_0_20px_rgba(0,0,0,0.05)] z-20' : 'bg-slate-100/50 border-transparent text-slate-400'}`}
				   style="writing-mode: vertical-rl; text-orientation: mixed;">
					<span class="text-[10px] font-black uppercase tracking-[0.3em]">01. Overview</span>
				</a>
				<a href={`${base}/projects`} 
				   class={`flex items-center justify-center py-10 px-2 border-y md:border-y-0 md:border-l-4 transition-all hover:bg-white/50 ${activeTab === 'projects' ? 'bg-white border-brand-orange shadow-[-10px_0_20px_rgba(0,0,0,0.05)] z-20' : 'bg-slate-100/50 border-transparent text-slate-400'}`}
				   style="writing-mode: vertical-rl; text-orientation: mixed;">
					<span class="text-[10px] font-black uppercase tracking-[0.3em]">02. Projects</span>
				</a>
				<a href={`${base}/resume`} 
				   class={`flex items-center justify-center py-10 px-2 border-y md:border-y-0 md:border-l-4 transition-all hover:bg-white/50 ${activeTab === 'resume' ? 'bg-white border-brand-orange shadow-[-10px_0_20px_rgba(0,0,0,0.05)] z-20' : 'bg-slate-100/50 border-transparent text-slate-400'}`}
				   style="writing-mode: vertical-rl; text-orientation: mixed;">
					<span class="text-[10px] font-black uppercase tracking-[0.3em]">03. Resume</span>
				</a>

				<div id="uni-indicator" class="hidden mt-auto mb-12">
					<a href={`${base}/uni?mode=uni`} 
					   class="flex items-center justify-center py-10 px-2 bg-brand-purple text-white md:rounded-l-xl shadow-lg hover:bg-brand-orange transition-colors"
					   style="writing-mode: vertical-rl; text-orientation: mixed;">
						<span class="text-[9px] font-black uppercase tracking-widest">Academic Hub</span>
					</a>
				</div>
			</aside>

			<main class="flex-1 bg-white shadow-[0_0_50px_rgba(0,0,0,0.05)] min-h-screen border-l border-slate-100">
				<div class="p-8 md:p-16 lg:p-24">
					<slot />
				</div>
			</main>
		</div>

		<footer class="relative z-10 bg-white border-t border-slate-100 py-16 px-6">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12">
				<div class="text-center md:text-left">
					<h2 class="font-neue font-black uppercase text-2xl mb-2">Dylan Purbrick</h2>
					<p class="text-[10px] font-mono text-slate-400 uppercase tracking-widest">Mechatronic Engineering // UTS 2026</p>
				</div>
				
				<div class="flex flex-col sm:flex-row items-center gap-6">
					<a href="mailto:dylan.m.purbrick@gmail.com" class="bg-brand-orange text-white px-10 py-4 rounded-full text-[11px] font-black uppercase tracking-widest hover:bg-brand-purple hover:scale-105 transition-all shadow-xl shadow-brand-orange/20">
						Send Email Message
					</a>
					<a href="https://linkedin.com/in/dylan-purbrick" target="_blank" class="text-slate-400 hover:text-brand-purple text-[10px] font-bold uppercase tracking-widest transition-colors">
						LinkedIn Profile
					</a>
				</div>
			</div>
		</footer>

		<script>
			function updateUniMode() {
				const params = new URLSearchParams(window.location.search);
				if (params.get('mode') === 'uni') {
					document.getElementById('uni-indicator')?.classList.remove('hidden');
					document.querySelectorAll('a').forEach(link => {
						const href = link.getAttribute('href');
						if (href && (href.startsWith('/') || href.startsWith(window.location.origin))) {
							const url = new URL(href, window.location.origin);
							url.searchParams.set('mode', 'uni');
							link.href = url.pathname + url.search + url.hash;
						}
					});
				}
			}
			updateUniMode();
			document.addEventListener('astro:page-load', updateUniMode);
		</script>
	</body>
</html>
