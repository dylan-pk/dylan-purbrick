---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  { 
    id: "agricultural-monitor", 
    title: "Agricultural Monitor", 
    category: "Simulated Robotics", 
    specs: ["Autonomous Navigation", "Simulink", "Sensor Array"], 
    image: `${base}/ag-robot.jpg`,
    portfolio: `${base}/Ag_Monitor_Portfolio.pdf`
  },
  { 
    id: "vertical-garden", 
    title: "Vertical Garden Robot", 
    category: "Embedded Systems", 
    specs: ["Environmental Sensing", "Automated Irrigation", "WiFi Logging"], 
    image: `${base}/garden-robot.jpg`,
    github: "https://github.com/dylanpurbrick/vertical-garden-monitor",
    portfolio: `${base}/Garden_Robot_Portfolio.pdf`
  },
  { 
    id: "gallery-robot", 
    title: "Gallery Robot", 
    category: "Autonomous Systems", 
    specs: ["ROS 2", "OpenCV", "90% Success"], 
    image: `${base}/gallery.jpg`,
    github: "https://github.com/dylanpurbrick/gallery-host",
    portfolio: `${base}/Gallery_Robot_Portfolio.pdf`
  },
  { 
    id: "pedometer", 
    title: "Pedometer Shield", 
    category: "Hardware", 
    specs: ["Altium", "Custom PCB", "I2C Interface"], 
    image: `${base}/pedometer.jpg` 
  },
  { 
    id: "printed-pliers", 
    title: "Printed Pliers", 
    category: "Additive Manufacturing", 
    specs: ["Print-in-Place", "Tolerance Control", "Fusion 360"], 
    image: `${base}/pliers.jpg` 
  },
  { 
    id: "defender", 
    title: "Land Rover Defender", 
    category: "System Modification", 
    specs: ["Solar Integration", "Winch Wiring", "Custom Storage"], 
    image: `${base}/defender.jpg` 
  }
];
---

<Layout title="Dylan Purbrick | Projects" activeTab="projects">
  <div class="max-w-6xl relative z-10">
    <header class="mb-24 border-b border-slate-200 pb-12">
        <h1 class="text-6xl font-black uppercase tracking-tighter mb-4">Technical Archive</h1>
        <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">Section_03 // Engineering Proofs & Personal Build Log</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((p) => <ProjectCard client:load {...p} />)}
    </div>
  </div>
</Layout>
