---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';
---

<Layout title="Dylan Purbrick | Engineering Projects" activeTab="projects">
  </Layout>
  <main class="max-w-7xl mx-auto px-6 py-48">
    <h1 class="text-9xl font-black uppercase tracking-tighter mb-32">
        <span class="font-wayfinder">Technical</span> <span class="font-neue text-brand-orange">Archive</span>
    </h1>

    <section id="datsun" class="py-32 border-t border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-20">
        <div>
            <span class="text-brand-purple font-mono text-[10px] uppercase tracking-widest">// Restoration</span>
            <h2 class="text-6xl font-black uppercase mt-4 mb-8 font-neue">Datsun <span class="text-brand-orange italic font-wayfinder lowercase">1200</span></h2>
            <p class="text-gray-600 mb-8 font-neue leading-relaxed">Mechanical and electrical restoration of a 1971 sedan. Project involved rust repair, paint, interior refresh, and addressing main loom electrical faults.</p>
            <ul class="font-mono text-[10px] space-y-2 text-brand-purple uppercase tracking-widest">
                <li>+ Loom redesign & repair</li>
                <li>+ Thermal/Sound insulation</li>
                <li>+ Classic integrity retention</li>
            </ul>
        </div>
        <div class="bg-gray-100 aspect-square rounded-sm overflow-hidden"><img src={`${base}/datsun.jpg`} class="object-cover h-full w-full" /></div>
    </section>

    <section id="gallery-robot" class="py-32 border-t border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-20">
        <div class="bg-gray-100 aspect-square rounded-sm overflow-hidden md:order-2"><img src={`${base}/gallery.jpg`} class="object-cover h-full w-full" /></div>
        <div class="md:order-1">
            <span class="text-brand-purple font-mono text-[10px] uppercase tracking-widest">// Autonomous Robotics</span>
            <h2 class="text-6xl font-black uppercase mt-4 mb-8 font-neue">Gallery <span class="text-brand-orange italic font-wayfinder uppercase">Host</span></h2>
            <p class="text-gray-600 mb-8 font-neue leading-relaxed">Developed a ROS 2 perception subsystem using OpenCV's ORB algorithm to recognize artwork from real-time camera data with 90% accuracy.</p>
        </div>
    </section>

    <section id="defender" class="py-32 border-t border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-20">
        <div>
            <span class="text-brand-purple font-mono text-[10px] uppercase tracking-widest">// Modification</span>
            <h2 class="text-6xl font-black uppercase mt-4 mb-8 font-neue">Land <span class="text-brand-orange italic font-wayfinder uppercase">Rover Defender</span></h2>
            <p class="text-gray-600 mb-8 font-neue leading-relaxed">Integration of off-grid electrical systems, including winch wiring, solar panels, and auxiliary power for touring and remote travel.</p>
        </div>
        <div class="bg-gray-100 aspect-square rounded-sm overflow-hidden"><img src={`${base}/defender.jpg`} class="object-cover h-full w-full" /></div>
    </section>

    <section id="pedometer" class="py-32 border-t border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-20">
        <div class="bg-gray-100 aspect-square rounded-sm overflow-hidden md:order-2"><img src={`${base}/pedometer.jpg`} class="object-cover h-full w-full" /></div>
        <div class="md:order-1">
            <span class="text-brand-purple font-mono text-[10px] uppercase tracking-widest">// Embedded Systems</span>
            <h2 class="text-6xl font-black uppercase mt-4 mb-8 font-neue">Custom <span class="text-brand-orange italic font-wayfinder uppercase">Pedometer</span></h2>
            <p class="text-gray-600 mb-8 font-neue leading-relaxed">Design and ECAD of a custom Arduino UNO shield in Altium365 to track steps using an ADXL335 accelerometer with >90% accuracy.</p>
        </div>
    </section>

    <section id="pliers" class="py-32 border-t border-gray-100 grid grid-cols-1 md:grid-cols-2 gap-20">
        <div>
            <span class="text-brand-purple font-mono text-[10px] uppercase tracking-widest">// Manufacturing</span>
            <h2 class="text-6xl font-black uppercase mt-4 mb-8 font-neue">Functional <span class="text-brand-orange italic font-wayfinder uppercase">Pliers</span></h2>
            <p class="text-gray-600 mb-8 font-neue leading-relaxed">Designed interlocking CAD geometry for a functional print-in-place set of pliers requiring zero assembly or post-processing.</p>
        </div>
        <div class="bg-gray-100 aspect-square rounded-sm overflow-hidden"><img src={`${base}/pliers.jpg`} class="object-cover h-full w-full" /></div>
    </section>
  </main>
</Layout>
