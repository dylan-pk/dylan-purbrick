---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#334155] text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden p-4 md:p-8 lg:p-12">
		
		<div class="fixed inset-0 pointer-events-none opacity-[0.05] z-0 bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>

		<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-stretch min-h-[90vh] shadow-[0_50px_100px_rgba(0,0,0,0.5)] bg-[#f1f5f9] rounded-b-3xl rounded-r-3xl relative overflow-hidden">
			
			<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/paper.png')] z-0"></div>

			<aside class="w-full md:w-24 lg:w-28 flex flex-row md:flex-col items-stretch relative z-10 p-0 m-0">
				
				<a href={`${base}/`} 
				   class={`group relative flex items-center justify-center pt-20 pb-12 px-2 transition-all duration-300 ${activeTab === 'home' ? 'text-brand-purple' : 'text-slate-400 hover:text-industrial-black'}`}>
					{activeTab === 'home' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
						01. Overview
					</span>
				</a>
				
				<div class="absolute w-24 h-24 right-0" style="top: 10rem; transform: translateY(-50%); text-align: right;">
					<div class="inline-block w-24 h-24 pointer-events-none" style="background: radial-gradient(circle at top left, transparent 48px, #334155 49px);"></div>
				</div>

				<a href={`${base}/projects`} 
				   class={`group relative flex items-center justify-center pt-24 pb-12 px-2 transition-all duration-300 ${activeTab === 'projects' ? 'text-brand-purple' : 'text-slate-400 hover:text-industrial-black'}`}>
					{activeTab === 'projects' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
						02. Projects
					</span>
				</a>

				<div class="absolute w-24 h-24 right-0" style="top: 22rem; transform: translateY(-50%); text-align: right;">
					<div class="inline-block w-24 h-24 pointer-events-none" style="background: radial-gradient(circle at top left, transparent 48px, #334155 49px);"></div>
				</div>

				<a href={`${base}/resume`} 
				   class={`group relative flex items-center justify-center pt-24 pb-12 px-2 transition-all duration-300 ${activeTab === 'resume' ? 'text-brand-purple' : 'text-slate-400 hover:text-industrial-black'}`}>
					{activeTab === 'resume' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
					<span class="text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
						03. Resume
					</span>
				</a>

				<div class="absolute w-24 h-24 right-0" style="top: 34rem; transform: translateY(-50%); text-align: right;">
					<div class="inline-block w-24 h-24 pointer-events-none" style="background: radial-gradient(circle at top left, transparent 48px, #334155 49px);"></div>
				</div>

				<div id="uni-indicator" class="hidden">
					<a href={`${base}/uni?mode=uni`} 
					   class={`group relative flex items-center justify-center pt-24 pb-12 px-2 transition-all duration-300 ${activeTab === 'uni' ? 'text-brand-purple' : 'text-brand-purple'}`}>
						{activeTab === 'uni' && <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
						<span class="text-[9px] font-black uppercase tracking-widest inline-block rotate-180" style="writing-mode: vertical-rl; text-orientation: mixed;">
							Academic Hub
						</span>
					</a>
				</div>
			</aside>

			<main class="flex-1 min-h-[85vh] relative z-20 border-l border-slate-200">
				
				<div class="absolute bottom-0 left-0 w-48 h-48 pointer-events-none" 
					 style="background: radial-gradient(circle at bottom left, transparent 180px, #334155 181px); z-index: 50;"></div>
				
				<div class="p-8 md:p-16 lg:p-20 relative z-10">
					<slot />
				</div>
			</main>
		</div>

		<footer class="mt-16 max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center px-6 font-neue text-[10px] text-slate-400 uppercase tracking-widest gap-4">
			<p>© 2026 Dylan Purbrick // Mechatronic systems dossier</p>
			<div class="flex gap-8">
				<a href="mailto:dylan.m.purbrick@gmail.com" class="hover:text-brand-orange">Email inquire</a>
				<a href="https://linkedin.com/in/dylan-purbrick" target="_blank" class="hover:text-brand-orange">LinkedIn</a>
			</div>
		</footer>

		<script>
			function updateUniMode() {
				const params = new URLSearchParams(window.location.search);
				if (params.get('mode') === 'uni') {
					document.getElementById('uni-indicator')?.classList.remove('hidden');
					document.querySelectorAll('a').forEach(link => {
						const href = link.getAttribute('href');
						if (href && (href.startsWith('/') || href.startsWith(window.location.origin))) {
							const url = new URL(href, window.location.origin);
							url.searchParams.set('mode', 'uni');
							link.href = url.pathname + url.search + url.hash;
						}
					});
				}
			}
			updateUniMode();
			document.addEventListener('astro:page-load', updateUniMode);
		</script>
	</body>
</html>
