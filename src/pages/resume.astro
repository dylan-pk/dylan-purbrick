---
import Layout from '../layouts/layout.astro';
const base = '/dylan-purbrick';
---

<Layout title="Dylan Purbrick | Resume" activeTab="resume">
  <div class="max-w-4xl">
    <header class="mb-20 border-b border-slate-100 pb-12 flex justify-between items-start">
        <div>
            <h1 class="text-6xl font-black uppercase tracking-tighter mb-2">Resume</h1>
            <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em]">Mechatronic Specialist</p>
        </div>
        <a href={`${base}/Dylan_Purbrick.pdf`} download class="text-[10px] font-black uppercase tracking-widest border-2 border-industrial-black px-6 py-3 hover:bg-industrial-black hover:text-white transition-all">
            Download PDF
        </a>
    </header>

    <div class="space-y-24 font-neue">
        <section>
            <h2 class="text-brand-orange font-black uppercase text-xs tracking-[0.3em] mb-12">01 // Work History</h2>
            <div class="space-y-16">
                <div>
                    <h3 class="text-2xl font-black uppercase">Engineering Assistant</h3>
                    <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6">Keith Engineering | 2025 – Present</p>
                    <ul class="space-y-4 text-slate-600 text-sm leading-relaxed max-w-2xl">
                        <li>• Contributed to equipment reconditioning evaluation and CAD modeling for industrial systems.</li>
                        <li>• Responsible for final quality assurance checks on manufacturing drawings and Bill of Materials (BOM) creation.</li>
                    </ul>
                </div>
                <div>
                    <h3 class="text-2xl font-black uppercase">Shift Supervisor</h3>
                    <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6">Lord Dudley Hotel | 2021 – Present</p>
                    <ul class="space-y-4 text-slate-600 text-sm leading-relaxed max-w-2xl">
                        <li>• Managing nightly sales exceeding $4,000 and supervising teams of up to 20 staff members.</li>
                        <li>• Maintaining performance under significant pressure while balancing a rigorous engineering degree.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="pt-24 border-t border-slate-100">
            <h2 class="text-brand-orange font-black uppercase text-xs tracking-[0.3em] mb-12">02 // Education</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div>
                    <h3 class="text-xl font-black uppercase">B. Engineering (Honours)</h3>
                    <p class="text-sm text-brand-purple font-bold mt-2">University of Technology Sydney</p>
                    <p class="text-xs text-slate-400 mt-4 italic">Distinction in Materials, Sensors, and Programming.</p>
                </div>
                <div>
                    <h3 class="text-xl font-black uppercase">Diploma of Engineering</h3>
                    <p class="text-sm text-brand-purple font-bold mt-2">UTS College</p>
                    <p class="text-xs text-slate-400 mt-4 italic">Graduated with High Distinction Average.</p>
                </div>
            </div>
        </section>
    </div>
  </div>
</Layout>
