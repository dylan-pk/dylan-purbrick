---
import Layout from '../layouts/layout.astro';
import ProjectCarousel from '../components/ProjectCarousel.jsx';
const base = '/dylan-purbrick';

// Restored: Full technical rotation including all 6 projects [cite: 37, 39, 40, 42, 68-70, 74-77, 140-149]
const allProjects = [
  { 
    id: "crop-guard", 
    title: "Crop-Guard", 
    category: "Agricultural Robotics", 
    specs: ["Autonomous Navigation", "Simulink", "Monitoring"], 
    image: `${base}/ag-robot.jpg`
  },
  { 
    id: "wallbug", 
    title: "Wallbug", 
    category: "Environmental Monitoring", 
    specs: ["Vertical Mobility", "Sensor Integration", "WiFi"], 
    image: `${base}/wallbug.jpg`
  },
  { 
    id: "gallery-robot", 
    title: "Gallery Robot", 
    category: "Autonomous Systems", 
    specs: ["ROS 2", "OpenCV", "90% Success"], 
    image: `${base}/gallery.jpg`
  },
  { 
    id: "datsun-1200", 
    title: "Datsun 1200", 
    category: "Restoration", 
    specs: ["Loom Repair", "Rust Remediation", "Interior"], 
    image: `${base}/datsun.jpg` 
  },
  { 
    id: "defender", 
    title: "Land Rover Defender", 
    category: "System Modification", 
    specs: ["Solar Integration", "Winch Wiring", "Storage"], 
    image: `${base}/defender.jpg` 
  },
  { 
    id: "printed-pliers", 
    title: "Printed Pliers", 
    category: "Additive Manufacturing", 
    specs: ["Print-in-Place", "Fusion 360", "Tolerance Control"], 
    image: `${base}/pliers.jpg` 
  }
];
---

<Layout title="Overview" activeTab="home">
  <div class="max-w-6xl relative z-10">
    <header class="mb-24 flex flex-col md:flex-row justify-between items-start gap-8">
        <div>
            <h1 class="text-7xl md:text-9xl font-black uppercase tracking-tighter leading-[0.8] mb-10 text-industrial-black">
                <span class="font-wayfinder italic">Dylan</span> <br/>
                <span class="text-brand-orange">Purbrick</span>
            </h1>
            <div class="h-1 w-24 bg-brand-purple"></div>
        </div>
        
        <a href={`${base}/Dylan_Purbrick_Resume.pdf`} download class="group flex items-center gap-4 border-2 border-industrial-black px-8 py-4 hover:bg-industrial-black transition-all">
            <span class="text-[11px] font-black uppercase tracking-widest group-hover:text-white">Download Resume</span>
            <svg class="w-4 h-4 group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/></svg>
        </a>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 mb-40">
        <div class="space-y-10 font-neue text-slate-700">
            <p class="text-3xl font-medium leading-tight text-industrial-black">
                Currently undergoing my final-year of a Bachelor of Engineering (Honours) in Mechatronics at UTS, while serving as an Engineering Assistant at Keith Engineering.            </p>
            <p class="text-xl leading-relaxed">
                My professional journey is driven by a deep passion for mechanical systems and a belief that genuine growth occurs through hands-on experience.            </p>
        </div>
        
        <div class="bg-white/60 p-12 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-brand-purple/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.5em] mb-8 font-bold">// Dossier_Summary</p>
            <p class="text-lg text-slate-600 leading-relaxed font-neue">
                Beyond technical aptitude in areas like Python, SolidWorks, and Fusion 360, I offer proven leadership and adaptability developed through co-founding the UTS MechSoc and managing high-pressure hospitality environments.            </p>
        </div>
    </div>

    <section class="py-20 bg-slate-50/50 rounded-[3rem] border border-slate-100">
        <div class="px-8 md:px-16 mb-16 flex flex-col md:flex-row justify-between items-end gap-6">
            <div>
                <h2 class="text-5xl font-black uppercase tracking-tighter text-industrial-black">Featured <span class="text-brand-orange">Works</span></h2>
                <p class="text-xs font-mono text-slate-400 mt-2 uppercase tracking-widest">Active Technical Rotations</p>
            </div>
            <a href={`${base}/projects`} class="text-[10px] font-black uppercase tracking-widest text-brand-purple hover:text-brand-orange transition-colors border-b-2 border-brand-purple/20 pb-1">View Full Archive</a>
        </div>

        <ProjectCarousel client:load projects={allProjects} base={base} />
    </section>
  </div>
</Layout>
