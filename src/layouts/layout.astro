---
import '../styles/global.css';
interface Props {
	title: string;
	activeTab: 'home' | 'cover-letter' | 'projects' | 'resume' | 'uni';
}
const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';

// Helper to define tab state classes
const getTabClasses = (tabName: string) => {
    const isActive = activeTab === tabName;
    return {
        container: isActive 
            ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-16' // Active: Full expansion
            : 'bg-slate-300/40 text-slate-500/40 py-8 hover:py-10 hover:bg-slate-300/60 hover:text-slate-700', // Inactive: Half-height + faded
        text: isActive 
            ? 'opacity-100' 
            : 'opacity-0 group-hover:opacity-100 transition-opacity duration-300', // Show text only on hover/active
        bar: isActive 
            ? 'block' 
            : 'hidden'
    };
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
	</head>
	<body class="bg-[#334155] text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden">
		<div class="fixed inset-0 pointer-events-none opacity-[0.05] z-0 bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>

		<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row min-h-screen pt-24 pb-48 px-4 md:px-0">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch relative z-30 transition-all duration-500">
				
				<a href={`${base}/`} class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${getTabClasses('home').container}`}>
					<div class={`absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)] ${getTabClasses('home').bar}`}></div>
					<span class={`text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180 ${getTabClasses('home').text}`} style="writing-mode: vertical-rl; text-orientation: mixed;">Overview</span>
				</a>

                <div id="cover-letter-indicator" class="hidden flex flex-col">
					<a href={`${base}/cover-letter?mode=uni`} class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${getTabClasses('cover-letter').container}`}>
						<div class={`absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)] ${getTabClasses('cover-letter').bar}`}></div>
						<span class={`text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180 ${getTabClasses('cover-letter').text}`} style="writing-mode: vertical-rl; text-orientation: mixed;">Cover Letter</span>
					</a>
				</div>

				<a href={`${base}/projects`} class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${getTabClasses('projects').container}`}>
					<div class={`absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)] ${getTabClasses('projects').bar}`}></div>
					<span class={`text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180 ${getTabClasses('projects').text}`} style="writing-mode: vertical-rl; text-orientation: mixed;">Projects</span>
				</a>

				<a href={`${base}/resume`} class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-slate-400/20 ${getTabClasses('resume').container}`}>
					<div class={`absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)] ${getTabClasses('resume').bar}`}></div>
					<span class={`text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180 ${getTabClasses('resume').text}`} style="writing-mode: vertical-rl; text-orientation: mixed;">Resume</span>
				</a>

				<div id="uni-indicator" class="hidden flex flex-col">
					<a href={`${base}/uni?mode=uni`} class={`group relative flex items-center justify-center rounded-l-xl transition-all duration-300 border-l border-t border-b border-slate-400/20 ${getTabClasses('uni').container}`}>
						<div class={`absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)] ${getTabClasses('uni').bar}`}></div>
						<span class={`text-[9px] font-black uppercase tracking-widest inline-block rotate-180 ${getTabClasses('uni').text}`} style="writing-mode: vertical-rl; text-orientation: mixed;">Reflection</span>
					</a>
				</div>
			</aside>

			<main class="flex-1 bg-[#f1f5f9] shadow-[0_40px_100px_rgba(0,0,0,0.5)] min-h-[85vh] rounded-r-3xl md:rounded-tr-3xl relative z-20 border-l border-slate-200">
				<div class="p-8 md:p-16 lg:p-24 relative z-10">
					<slot />
				</div>
			</main>
		</div>
        </body>
</html>