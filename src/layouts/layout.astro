---
import '../styles/global.css';
interface Props {
	title: string;
	activeTab: 'home' | 'cover-letter' | 'projects' | 'resume' | 'uni';
}
const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';

// Define the "Assembly Line" sequence
const sequence = [
    { id: 'home', path: '/' },
    { id: 'cover-letter', path: '/cover-letter', uniOnly: true },
    { id: 'projects', path: '/projects' },
    { id: 'resume', path: '/resume' },
    { id: 'uni', path: '/uni', uniOnly: true },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/icon.svg`} />
		<title>{title} | Dylan Purbrick</title>
		<style>
			/* The Pronounced Engineering Grid */
			.bg-engineering-grid {
				background-color: #1e293b; /* Darker slate for better contrast */
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.05) 2px, transparent 2px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.05) 2px, transparent 2px),
					linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
				background-size: 100px 100px, 100px 100px, 20px 20px, 20px 20px;
				background-attachment: fixed;
			}
		</style>
	</head>
	<body class="bg-engineering-grid text-industrial-black font-neue antialiased min-h-screen relative overflow-x-hidden transition-opacity duration-700">
		
		<div class="relative z-10 max-w-6xl mx-auto flex flex-col md:flex-row min-h-screen pt-24 pb-48 px-4 md:px-0">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch relative z-30">
				</aside>

			<main class="flex-1 bg-[#f1f5f9] shadow-[0_40px_100px_rgba(0,0,0,0.5)] min-h-[85vh] rounded-r-3xl md:rounded-tr-3xl relative z-20 border-l border-slate-200 flex flex-col overflow-hidden">
				<div class="p-8 md:p-16 lg:p-20 relative z-10 flex-1">
					<slot />
				</div>

				<footer class="mt-auto border-t border-slate-200 p-8 md:px-16 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-[9px] font-mono text-slate-400 uppercase tracking-widest">© 2026 Dylan Purbrick | Under Graduate Engineer</p>
					<a href="mailto:dylan.m.purbrick@gmail.com" class="text-[10px] font-black uppercase tracking-widest text-brand-purple hover:text-brand-orange transition-colors">dylan.m.purbrick@gmail.com</a>
				</footer>

				<div id="scroll-limit-switch" class="h-1 w-full pointer-events-none"></div>
			</main>
		</div>

		<script define:vars={{ sequence, base, activeTab }}>
			function initAutomation() {
				const params = new URLSearchParams(window.location.search);
				const isUniMode = params.get('mode') === 'uni';

				// 1. Update Uni Mode Visibility
				if (isUniMode) {
					document.getElementById('uni-tab-wrapper')?.classList.remove('hidden');
					document.getElementById('cover-letter-tab-wrapper')?.classList.remove('hidden');
				}

				// 2. Automated Page Transition Logic
				const currentPath = window.location.pathname.replace(/\/$/, "");
				// Filter sequence based on mode
				const activeSequence = sequence.filter(s => !s.uniOnly || isUniMode);
				const currentIndex = activeSequence.findIndex(s => s.id === activeTab);
				const nextSection = activeSequence[currentIndex + 1];

				if (nextSection) {
					const observer = new IntersectionObserver((entries) => {
						if (entries[0].isIntersecting) {
							// Trigger transition
							document.body.style.opacity = '0';
							setTimeout(() => {
								const nextUrl = `${base}${nextSection.path}${isUniMode ? '?mode=uni' : ''}`;
								window.location.href = nextUrl;
							}, 600);
						}
					}, { threshold: 0.1 });

					const sensor = document.getElementById('scroll-limit-switch');
					if (sensor) observer.observe(sensor);
				}
			}

			// Run on load and on Astro view transitions
			initAutomation();
			document.addEventListener('astro:page-load', initAutomation);
		</script>
	</body>
</html>