---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#2c2c2c] text-industrial-black font-neue antialiased min-h-screen p-4 md:p-12">
		
		<div id="uni-sidebar" class="hidden fixed right-0 top-1/3 z-[200]">
			<a 
				href={`${base}/uni?mode=uni`} 
				class="bg-brand-purple text-white px-3 py-6 flex items-center shadow-xl border-l border-white/20 hover:bg-brand-orange transition-all duration-300"
				style="writing-mode: vertical-rl; text-orientation: mixed; border-radius: 8px 0 0 8px;"
			>
				<span class="font-neue text-[9px] font-black uppercase tracking-[0.2em]">Academic Submission</span>
			</a>
		</div>

		<div class="max-w-6xl mx-auto">
			<nav class="flex items-end gap-1 ml-4 md:ml-8">
				<a href={`${base}/?mode=${activeTab === 'uni' ? 'uni' : ''}`} 
				   class={`px-6 py-3 rounded-t-xl text-[10px] font-black uppercase tracking-widest transition-all ${activeTab === 'home' ? 'bg-[#f3e5ab] text-industrial-black h-12 shadow-[-4px_-4px_10px_rgba(0,0,0,0.1)]' : 'bg-[#e2d49e] text-gray-600 h-10 hover:h-11'}`}>
					01. Overview
				</a>
				<a href={`${base}/projects?mode=${activeTab === 'uni' ? 'uni' : ''}`} 
				   class={`px-6 py-3 rounded-t-xl text-[10px] font-black uppercase tracking-widest transition-all ${activeTab === 'projects' ? 'bg-[#f3e5ab] text-industrial-black h-12 shadow-[0_-4px_10px_rgba(0,0,0,0.1)]' : 'bg-[#e2d49e] text-gray-600 h-10 hover:h-11'}`}>
					02. Projects
				</a>
				<a href={`${base}/resume?mode=${activeTab === 'uni' ? 'uni' : ''}`} 
				   class={`px-6 py-3 rounded-t-xl text-[10px] font-black uppercase tracking-widest transition-all ${activeTab === 'resume' ? 'bg-[#f3e5ab] text-industrial-black h-12 shadow-[4px_-4px_10px_rgba(0,0,0,0.1)]' : 'bg-[#e2d49e] text-gray-600 h-10 hover:h-11'}`}>
					03. Resume
				</a>
			</nav>

			<div class="bg-[#f3e5ab] min-h-[80vh] shadow-2xl rounded-tr-3xl rounded-b-3xl relative overflow-hidden border-t border-white/40">
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/paper.png')]"></div>
				
				<div class="relative z-10 p-8 md:p-16">
					<slot />
				</div>
			</div>

			<footer class="mt-8 flex justify-between items-center px-4 md:px-8 font-neue text-[10px] text-gray-400 uppercase tracking-widest">
				<p>Dylan Purbrick // Mechatronic Portfolio 2026</p>
				<div class="flex gap-6">
					<a href="mailto:dylan.m.purbrick@gmail.com" class="hover:text-brand-orange">Contact</a>
					<a href="https://linkedin.com/in/dylan-purbrick" target="_blank" class="hover:text-brand-orange">LinkedIn</a>
				</div>
			</footer>
		</div>

		<script>
			// Uni Mode Logic
			const urlParams = new URLSearchParams(window.location.search);
			const isUniMode = urlParams.get('mode') === 'uni';

			if (isUniMode) {
				document.getElementById('uni-sidebar')?.classList.remove('hidden');
				document.querySelectorAll('a').forEach(link => {
					const href = link.getAttribute('href');
					if (href && (href.startsWith('/') || href.includes(window.location.hostname))) {
						const url = new URL(href, window.location.origin);
						url.searchParams.set('mode', 'uni');
						link.href = url.pathname + url.search + url.hash;
					}
				});
			}
		</script>
	</body>
</html>
