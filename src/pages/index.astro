---
import Layout from '../layouts/layout.astro';
import ProjectCarousel from '../components/ProjectCarousel.jsx';
const base = '/dylan-purbrick';
const resumePath = `${base}/Dylan_Purbrick_Resume.pdf`;

const allProjects = [
  { id: "wallbug", title: "Wallbug", category: "Embedded Systems", image: `${base}/images/wallbug/hero.png`, specs: ["C++", "Sensors"] },
  { id: "gallery-host", title: "Gallery Host", category: "ROS 2", image: `${base}/images/gallery/hero.png`, specs: ["Python", "OpenCV"] },
  { id: "datsun-1200", title: "Datsun 1200", category: "Restoration", image: `${base}/images/datsun-1200/hero.jpg`, specs: ["Electrical", "CAD"] },
  { id: "pedometer", title: "Pedometer", category: "PCB Design", image: `${base}/images/pedometer/hero.jpg`, specs: ["Altium", "Arduino"] },
  { id: "defender-mod", title: "Defender Mod", category: "Electrical", image: `${base}/images/defender/hero.jpg`, specs: ["Off-Grid", "Wiring"] },
  { id: "printed-pliers", title: "3D Pliers", category: "Additive Mfg", image: `${base}/images/pliers/hero.jpg`, specs: ["CAD", "Tolerance"] },
  { id: "crop-guard", title: "Crop-Guard", category: "Robotics", image: `${base}/images/crop-guard/hero.png`, specs: ["Simulink", "Pathing"] }
];
---

<Layout title="Overview" activeTab="home">
  <div class="max-w-5xl mx-auto relative z-10">
    
    <header class="mb-32 flex flex-col md:flex-row items-center justify-between border-b border-slate-200 pb-16">
        <div class="text-center md:text-left mb-8 md:mb-0">
            <h1 class="text-7xl lg:text-8xl font-black uppercase tracking-tighter leading-[0.8] mb-6 text-industrial-black">
                Dylan <br/><span class="text-brand-orange">Purbrick</span>
            </h1>
            <p class="text-order-3 text-brand-purple tracking-[0.4em] font-bold">
                Engineering Assistant // Mechatronic Student
            </p>
        </div>

        <div class="relative group">
            <img src={`${base}/images/dylan-profile.jpg`} alt="Dylan Purbrick" class="w-40 h-40 lg:w-48 lg:h-48 rounded-full object-cover grayscale hover:grayscale-0 transition-all duration-700 border-4 border-white shadow-2xl" />
            <div class="absolute inset-0 rounded-full border-2 border-brand-orange scale-110 opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
        </div>
    </header>

    <section class="mb-32 grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-8 space-y-8">
            <h2 class="text-order-1 text-brand-orange">01 // Career Objective</h2>
            <p class="text-3xl font-medium leading-tight text-industrial-black">Driven by a passion for hands-on experience and practical immersion.</p>
            <p class="text-order-2 max-w-2xl">My skills in problem-solving and cross-functional teamwork allow me to add immediate value to professional engineering environments.</p>
            <div class="pt-8">
                <a href={resumePath} download class="inline-flex items-center gap-6 bg-industrial-black px-10 py-5 hover:bg-brand-orange transition-all rounded-sm shadow-2xl group">
                    <span class="text-order-1 text-white tracking-widest">Download Full Credentials</span>
                </a>
            </div>
        </div>

        <div class="lg:col-span-4 bg-slate-100 p-8 rounded-2xl border border-slate-200 h-fit">
            <h3 class="text-order-1 text-brand-purple mb-6 border-b border-slate-300 pb-2">Status_Report</h3>
            <ul class="space-y-4">
                <li class="flex justify-between items-center"><span class="text-order-3">Education:</span> <span class="text-order-2 text-industrial-black font-bold">UTS Sydney</span></li>
                <li class="flex justify-between items-center"><span class="text-order-3">Course|Major:</span> <span class="text-order-2 text-industrial-black font-bold">Engineering|Mechatronics</span></li>
                <li class="flex justify-between items-center"><span class="text-order-3">Current:</span> <span class="text-order-2 text-industrial-black font-bold text-brand-orange">Keith Engineering</span></li>
            </ul>
        </div>
    </section>

    <section class="mb-48">
        <div class="flex items-center justify-between mb-12">
            <h2 class="text-order-1 text-brand-orange">02 // Featured Works</h2>
            <a href={`${base}/projects`} class="text-order-1 text-brand-purple hover:text-brand-orange transition-colors">Technical Archive —></a>
        </div>
        <div class="bg-white/50 p-6 md:p-12 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden">
            <ProjectCarousel client:load projects={allProjects} base={base} />
        </div>
    </section>
  </div>
</Layout>