---
import '../styles/global.css';

interface Props {
	title: string;
	activeTab: 'home' | 'projects' | 'resume' | 'uni';
}

const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,900&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0f172a] text-industrial-black font-neue antialiased min-h-screen p-4 md:p-8 lg:p-12">
		
		<div id="uni-sidebar" class="hidden fixed right-0 top-1/3 z-[200]">
			<a 
				href={`${base}/uni?mode=uni`} 
				class="bg-brand-purple text-white px-3 py-6 flex items-center shadow-2xl border-l border-white/10 hover:bg-brand-orange transition-all duration-300"
				style="writing-mode: vertical-rl; text-orientation: mixed; border-radius: 12px 0 0 12px;"
			>
				<span class="font-neue text-[9px] font-black uppercase tracking-[0.2em]">Academic Submission</span>
			</a>
		</div>

		<div class="max-w-7xl mx-auto">
			<nav class="flex items-end gap-1 ml-2 md:ml-6">
				<a href={`${base}/`} 
				   class={`px-8 py-3 rounded-t-2xl text-[10px] font-black uppercase tracking-widest transition-all ${activeTab === 'home' ? 'bg-[#f1f5f9] text-brand-purple h-14 shadow-[-4px_-4px_15px_rgba(0,0,0,0.3)] z-30' : 'bg-[#cbd5e1] text-slate-500 h-11 hover:h-12 z-10'}`}>
					01. Overview
				</a>
				<a href={`${base}/projects`} 
				   class={`px-8 py-3 rounded-t-2xl text-[10px] font-black uppercase tracking-widest transition-all ${activeTab === 'projects' ? 'bg-[#f1f5f9] text-brand-purple h-14 shadow-[0_-4px_15px_rgba(0,0,0,0.3)] z-30' : 'bg-[#cbd5e1] text-slate-500 h-11 hover:h-12 z-20'}`}>
					02. Projects
				</a>
				<a href={`${base}/resume`} 
				   class={`px-8 py-3 rounded-t-2xl text-[10px] font-black uppercase tracking-widest transition-all ${activeTab === 'resume' ? 'bg-[#f1f5f9] text-brand-purple h-14 shadow-[4px_-4px_15px_rgba(0,0,0,0.3)] z-30' : 'bg-[#cbd5e1] text-slate-500 h-11 hover:h-12 z-10'}`}>
					03. Resume
				</a>
			</nav>

			<div class="bg-[#f1f5f9] min-h-[85vh] shadow-[0_20px_50px_rgba(0,0,0,0.5)] rounded-tr-3xl rounded-b-3xl relative overflow-hidden border-t border-white/50">
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/graphy.png')]"></div>
				
				<div class="relative z-10 p-6 md:p-12 lg:p-20">
					<slot />
				</div>
			</div>

			<footer class="mt-10 flex flex-col md:flex-row justify-between items-center px-4 font-neue text-[10px] text-slate-500 uppercase tracking-widest gap-4">
				<p>© 2026 Dylan Purbrick // Mechatronic Systems Dossier</p>
				<div class="flex gap-8">
					<a href="mailto:dylan.m.purbrick@gmail.com" class="hover:text-brand-orange transition-colors">Email</a>
					<a href
