---
import Layout from '../layouts/layout.astro';
import ProjectCard from '../components/ProjectCard.jsx';
const base = '/dylan-purbrick';

const projects = [
  { id: "datsun", title: "Datsun 1200", category: "Restoration", specs: ["Loom Repair", "Rust Remediation", "Interior"], image: `${base}/datsun.jpg` },
  { id: "gallery-robot", title: "Gallery Robot", category: "Robotics", specs: ["ROS 2", "OpenCV", "90% Success"], image: `${base}/gallery.jpg` },
  { id: "defender", title: "Land Rover", category: "Modification", specs: ["Solar Wiring", "Winch", "Storage"], image: `${base}/defender.jpg` },
  { id: "pedometer", title: "Pedometer Shield", category: "Embedded", specs: ["Custom PCB", "Altium", "Arduino"], image: `${base}/pedometer.jpg` },
  { id: "pliers", title: "Printed Pliers", category: "Manufacturing", specs: ["Print-in-Place", "Tolerance", "CAD"], image: `${base}/pliers.jpg` }
];
---

<Layout title="Dylan Purbrick | Overview" activeTab="home">
  <div class="max-w-5xl">
    <header class="mb-24">
        <h1 class="text-7xl md:text-9xl font-black uppercase tracking-tighter leading-[0.8] mb-8">
            <span class="font-wayfinder italic">Dylan</span> <br/>
            <span class="text-brand-orange">Purbrick</span>
        </h1>
        <div class="h-1 w-20 bg-brand-purple"></div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 mb-32">
        <div class="space-y-8">
            <p class="text-2xl font-medium text-slate-700 leading-snug font-neue">
                I am currently undergoing my final-year of study of a Bachelor of Engineering (Honours) in Mechatronic Engineering at UTS, and currently an Engineering Assistant at Keith Engineering.
            </p>
            <p class="text-slate-500 leading-relaxed font-neue">
                My professional journey is driven by a deep passion for furthering my mechanical understanding and gaining hands-on experience, developed through leadership roles and technical exploration.
            </p>
        </div>
        <div class="bg-slate-50 p-10 rounded-2xl border border-slate-100">
            <p class="text-brand-purple font-mono text-[10px] uppercase tracking-[0.4em] mb-6">// Profile_Summary</p>
            <p class="text-sm text-slate-600 leading-loose font-neue">
                Beyond technical aptitude in Python and SolidWorks, I offer proven transferable skills developed through leadership roles, including co-founding the UTS MechSoc and supervising teams in fast-paced environments.
            </p>
        </div>
    </div>

    <section id="projects">
        <div class="flex justify-between items-end mb-12 border-b border-slate-100 pb-6">
            <h2 class="text-4xl font-black uppercase tracking-tighter">Technical <span class="text-brand-orange">Dossier</span></h2>
            <p class="text-[9px] font-mono uppercase tracking-widest text-slate-300">Section_02 // Selected Projects</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {projects.map((p) => <ProjectCard client:load {...p} />)}
        </div>
    </section>
  </div>
</Layout>
