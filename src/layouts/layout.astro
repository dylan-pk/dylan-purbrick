---
import '../styles/global.css';
const { title, activeTab } = Astro.props;
const base = '/dylan-purbrick';

const tabs = [
    { id: 'home', label: 'Overview', path: '/' },
    { id: 'cover-letter', label: 'Cover Letter', path: '/cover-letter', uniOnly: true },
    { id: 'projects', label: 'Projects', path: '/projects' },
    { id: 'resume', label: 'Resume', path: '/resume' },
    { id: 'uni', label: 'Reflection', path: '/uni', uniOnly: true },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/icon.svg`} />
		<title>{title} | Dylan Purbrick</title>
		<style>
			.bg-engineering-grid {
				background-color: #0f172a; /* Deeper slate for text pop */
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.08) 2px, transparent 2px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.08) 2px, transparent 2px);
				background-size: 128px 128px;
				background-attachment: fixed;
			}
		</style>
	</head>
	<body class="bg-engineering-grid text-industrial-black font-neue antialiased min-h-screen transition-opacity duration-500 opacity-100">
		
		<div class="relative z-10 max-w-6xl mx-auto flex flex-col md:flex-row min-h-screen pt-24 pb-48 px-4 md:px-0">
			
			<aside class="w-full md:w-20 lg:w-24 flex flex-row md:flex-col items-stretch relative z-30">
				{tabs.map((tab) => {
					const isActive = activeTab === tab.id;
					return (
						<div id={`${tab.id}-tab-wrapper`} class={tab.uniOnly ? 'hidden' : 'block'}>
							<a 
								href={`${base}${tab.path}`} 
								class={`nav-tab group relative flex items-center justify-center rounded-l-xl transition-all duration-500 border-l border-y border-white/10 backdrop-blur-md
									${isActive 
                                        ? 'bg-[#f1f5f9] text-brand-purple z-40 translate-x-[1px] py-20' 
                                        /* READABILITY FIX: Increased opacity and darker text for inactive tabs */
                                        : 'bg-slate-800/80 text-slate-100 py-10 hover:py-12 hover:bg-slate-700'}
								`}
							>
								{isActive && <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-brand-orange rounded-r-full shadow-[2px_0_10px_rgba(234,88,12,0.4)]"></div>}
								<span class={`text-[10px] font-black uppercase tracking-[0.3em] inline-block rotate-180 ${isActive ? 'opacity-100' : 'opacity-70'}`} style="writing-mode: vertical-rl; text-orientation: mixed;">
									{tab.label}
								</span>
							</a>
						</div>
					);
				})}
			</aside>

			<main class="flex-1 bg-[#f1f5f9] shadow-[0_40px_100px_rgba(0,0,0,0.5)] min-h-[85vh] rounded-r-3xl md:rounded-tr-3xl relative z-20 border-l border-slate-200 flex flex-col overflow-hidden">
				<div id="scroll-prev-sensor" class="h-px w-full pointer-events-none"></div>

                <div class="p-8 md:p-16 lg:p-20 relative z-10 flex-1">
					<slot />
				</div>

				<footer class="mt-auto border-t border-slate-200 p-8 md:px-16 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-[9px] font-mono text-slate-400 uppercase tracking-widest">© 2026 Dylan Purbrick | Under Graduate Engineer</p>
					<a href="mailto:dylan.m.purbrick@gmail.com" class="text-[10px] font-black uppercase tracking-widest text-brand-purple hover:text-brand-orange transition-colors">dylan.m.purbrick@gmail.com</a>
				</footer>

				<div id="scroll-next-sensor" class="h-px w-full pointer-events-none"></div>
			</main>
		</div>

		<script define:vars={{ tabs, base, activeTab }}>
			function initSystem() {
				const params = new URLSearchParams(window.location.search);
				const isUniMode = params.get('mode') === 'uni';

				if (isUniMode) {
					document.getElementById('uni-tab-wrapper')?.classList.remove('hidden');
					document.getElementById('cover-letter-tab-wrapper')?.classList.remove('hidden');
				}

				const fadeAndGo = (url) => {
					document.body.style.opacity = '0';
					setTimeout(() => window.location.href = url, 500);
				};

				// Tab Controls
				document.querySelectorAll('.nav-tab').forEach(tab => {
					tab.addEventListener('click', (e) => {
						e.preventDefault();
						const url = new URL(tab.href);
						if (isUniMode) url.searchParams.set('mode', 'uni');
						fadeAndGo(url.toString());
					});
				});

				// Bidirectional Navigation Logic
				const activeSequence = tabs.filter(t => !t.uniOnly || isUniMode);
				const currentIndex = activeSequence.findIndex(t => t.id === activeTab);
				
				const nextSection = activeSequence[currentIndex + 1];
                const prevSection = activeSequence[currentIndex - 1];

				const observerOptions = { threshold: 0.1 };

				// Next Sensor (Down)
				if (nextSection) {
					const nextObserver = new IntersectionObserver((entries) => {
						if (entries[0].isIntersecting) {
							const url = new URL(window.location.origin + base + nextSection.path);
							if (isUniMode) url.searchParams.set('mode', 'uni');
							fadeAndGo(url.toString());
						}
					}, observerOptions);
					nextObserver.observe(document.getElementById('scroll-next-sensor'));
				}

                // Previous Sensor (Up)
                if (prevSection) {
                    const prevObserver = new IntersectionObserver((entries) => {
                        // We check if we are at the top AND moving up
                        if (entries[0].isIntersecting && window.scrollY < 100) {
                            const url = new URL(window.location.origin + base + prevSection.path);
                            if (isUniMode) url.searchParams.set('mode', 'uni');
                            fadeAndGo(url.toString());
                        }
                    }, observerOptions);
                    prevObserver.observe(document.getElementById('scroll-prev-sensor'));
                }
			}

			initSystem();
			document.addEventListener('astro:page-load', initSystem);
		</script>
	</body>
</html>